port: 7890
socks-port: 7891
redir-port: 7892
tproxy-port: 7893
allow-lan: true
mode: Rule
log-level: info
external-controller: 127.0.0.1:9090
dns:
  enable: false
  listen: 0.0.0.0:53
  enhanced-mode: fake-ip
  nameserver:
    - tls://dns.rubyfish.cn:853
    - 119.29.29.29
    - 223.5.5.5
  fallback:
    - tls://1.1.1.1:853
    - tcp://1.1.1.1:53
    - tcp://208.67.222.222:443
    - tls://dns.google
    - tls://dns.rubyfish.cn:853
    - 114.114.114.114
    - 8.8.8.8
tun:
  enable: false
proxies:
{{ proxies | yaml_block }}
proxy-groups:
  - name: ProxyList
    type: select
    proxies:
      - AutoGroup
      - DIRECT
{% for region_group in surge_region_groups %}
      - {{ region_group.name }}
{% endfor %}
{% for proxy_name in proxy_names %}
      - {{ proxy_name | tojson }}
{% endfor %}
    icon: https://raw.githubusercontent.com/sunliang711/icons/main/surge.webp
  - name: FinalList
