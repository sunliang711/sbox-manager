{% endfor %}
    icon: https://raw.githubusercontent.com/sunliang711/icons/main/surge.webp
  - name: AutoGroup
    type: url-test
    url: {{ test_url }}
    interval: 120
    tolerance: 200
    proxies:
{% for proxy_name in proxy_names %}
      - {{ proxy_name | tojson }}
{% endfor %}
    icon: https://raw.githubusercontent.com/sunliang711/icons/main/auto.png
{% for region_group in surge_region_groups %}
