# VMess QUIC inbound，可放入 instance.inbounds。
- name: vmess-quic
  type: vmess
  listen: 0.0.0.0
  port: 24104
  tag: vmess-vmess-quic
  udp: true
  tls:
    enabled: true # QUIC transport 必须启用 TLS。
    server_name: proxy.example.com
    insecure: false
    alpn: [h3]
    certificate_path: /etc/ssl/sbox/fullchain.pem # TLS inbound 必填服务端证书。
    key_path: /etc/ssl/sbox/private.key # TLS inbound 必填私钥。
  transport:
    type: quic
  users:
    - name: alice
      uuid: "{{ .VmessUUID }}"
      alter_id: 0
      remark: US VMess QUIC
      tag: edge-us-vmess-quic
  subscription:
    enabled: true
    user: alice
    server: "{{ .SubscriptionServer }}"
    remark: US VMess QUIC
    region: US
