# VLESS REALITY Vision inbound，可放入 instance.inbounds。
- name: vless-reality-vision
  type: vless
  listen: 0.0.0.0
  port: 24115
  tag: vless-vless-reality-vision
  udp: true
  tls:
    enabled: true
    server_name: {{ .RealityServerName }}
    reality:
      enabled: true
      handshake_server: {{ .RealityServerName }}
      handshake_server_port: 443
      private_key: "{{ .RealityPrivateKey }}" # REALITY 服务端私钥，生产环境请替换。
      public_key: "{{ .RealityPublicKey }}" # 仅用于订阅导出，不写入 sing-box 服务端 JSON。
      short_ids: ["{{ .RealityShortID }}"]
  users:
    - name: alice
      uuid: "{{ .VlessUUID }}"
      flow: xtls-rprx-vision
      remark: US VLESS REALITY Vision
      tag: edge-us-vless-reality-vision
  subscription:
    enabled: true
    user: alice
    server: "{{ .SubscriptionServer }}"
    remark: US VLESS REALITY Vision
    region: US
