# VLESS inbound（WebSocket），可放入 instance.inbounds。
- name: vless-ws
  type: vless
  listen: 0.0.0.0
  port: 24110
  tag: vless-vless-ws
  udp: true
  tls:
    enabled: true # 可按需启用 TLS。
    server_name: proxy.example.com
    insecure: false
    # alpn: [h2, http/1.1] # 可选 TLS ALPN；服务端明确需要时再启用。
    certificate_path: /etc/ssl/sbox/fullchain.pem # TLS inbound 必填服务端证书。
    key_path: /etc/ssl/sbox/private.key # TLS inbound 必填私钥。
  transport:
    type: ws
    path: /vless-websocket
    headers:
      Host: proxy.example.com
  users:
    - name: alice
      uuid: "{{ .VlessUUID }}" # VLESS 必填 UUID。
      remark: US VLESS WS
      tag: edge-us-vless-ws
  subscription:
    enabled: true
    user: alice
    server: "{{ .SubscriptionServer }}"
    remark: US VLESS WS
    region: US
