# VLESS gRPC outbound。
- name: vless-grpc-upstream
  type: vless
  server: vless.example.com
  port: 443
  uuid: "{{ .VlessUUID }}"
  flow: xtls-rprx-vision
  tls:
    enabled: true
    server_name: vless.example.com
    insecure: false
    alpn: [h2, http/1.1]
  transport:
    type: grpc
    service_name: TunService
    idle_timeout: 30s
    ping_timeout: 15s
    permit_without_stream: false
