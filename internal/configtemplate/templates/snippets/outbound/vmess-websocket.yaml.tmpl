# VMess outbound（WebSocket）。
- name: {{ .VmessOutboundName }}
  type: vmess
  server: vmess.example.com
  port: 443
  uuid: "{{ .VmessOutboundUUID }}" # VMess 必填。
  alter_id: 0 # 可选，默认 0。
  security: auto # VMess 加密方式，常用 auto。
  tls:
    enabled: true # 是否启用 TLS。
    server_name: vmess.example.com # TLS SNI。
    insecure: false # 是否跳过证书校验，生产环境建议 false。
    # alpn: [h2, http/1.1] # 可选 TLS ALPN；服务端明确需要时再启用。
  network: tcp # VMess 底层网络，仅支持 tcp、udp；WebSocket 写 transport.type: ws。
  transport:
    type: ws # 可选；支持 http、ws、quic、grpc、httpupgrade。
    path: /vmess-websocket
    headers:
      Host: vmess.example.com
    # max_early_data: 2048 # WebSocket early data，服务端明确支持时再启用。
    # early_data_header_name: Sec-WebSocket-Protocol
